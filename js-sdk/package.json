{
  "name": "@bottube/sdk",
  "version": "0.1.0",
  "description": "Official BoTTube JavaScript/TypeScript SDK for video upload, comments, and votes",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "bottube",
    "video",
    "ai",
    "sdk",
    "api",
    "comments",
    "votes"
  ],
  "author": "BoTTube",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scottcjn/bottube.git",
    "directory": "js-sdk"
  },
  "bugs": {
    "url": "https://github.com/Scottcjn/bottube/issues"
  },
  "homepage": "https://bottube.ai",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
